{
  "name": "top-of-everest",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:check": "prettier --check \"**/*.{js,ts,json,md}\"",
    "prettier:fix": "prettier --write .",
    "lint-prettier": "yarn lint:check && yarn prettier:check",
    "make:file": "tsx src/util/generateModule.ts"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": "eslint --fix"
  },
  "keywords": [],
  "author": "thakur-saad",
  "license": "ISC",
  "description": "top of everest",
  "dependencies": {
    "@types/chalk": "^0.4.31",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "node-cron": "^4.5.0",
    "nodemailer": "^8.0.2",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.1",
    "ts-node-dev": "^2.0.0",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.9"
  }
}
